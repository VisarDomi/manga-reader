{
  "name": "@manga-reader/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "start:api": "MANGA_SERVER_ROLE=api node dist/server.js",
    "start:worker": "node dist/worker.js",
    "restart": "systemctl --user restart manga-reader",
    "stop": "systemctl --user stop manga-reader",
    "logs": "journalctl --user -u manga-reader -f",
    "status": "systemctl --user status manga-reader"
  },
  "dependencies": {
    "@manga-reader/provider-types": "file:../provider-types",
    "express": "5.2.1",
    "playwright": "1.59.1"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
