{
  "name": "@manga-reader/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "restart": "systemctl --user restart comix-backend",
    "stop": "systemctl --user stop comix-backend",
    "logs": "journalctl --user -u comix-backend -f",
    "status": "systemctl --user status comix-backend"
  },
  "dependencies": {
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
