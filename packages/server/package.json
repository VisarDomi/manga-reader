{
  "name": "@manga-reader/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "restart": "systemctl --user restart manga-reader",
    "stop": "systemctl --user stop manga-reader",
    "logs": "journalctl --user -u manga-reader -f",
    "status": "systemctl --user status manga-reader"
  },
  "dependencies": {
    "express": "^4.21.0",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
